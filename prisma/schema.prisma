generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id             String   @id @default(cuid())
  anonymousName  String
  content        String
  category       String   @default("General")
  status         String   @default("pending") // pending, approved, rejected
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  replies        Reply[]
}

model Reply {
  id             String   @id @default(cuid())
  postId         String
  post           Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  anonymousName  String
  content        String
  status         String   @default("pending") // pending, approved, rejected — now requires admin approval
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String   @default("")
  role      String   @default("admin") // admin, superadmin
  secret    String                          // hashed login secret
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactInfo {
  id        String   @id @default(cuid())
  key       String   @unique               // e.g. "primary_phone", "email", "whatsapp", "address"
  value     String
  label     String                          // display label
  icon      String   @default("phone")       // lucide icon name
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
